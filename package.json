{
  "name": "ebl-tablet-studio",
  "version": "0.1.0",
  "description": "Unified desktop app for cuneiform tablet image renaming, segmentation, and stitching. Successor to tablet-image-renamer and ebl-photo-stitcher.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:dir": "electron-builder --win --dir"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "exifr": "^7.1.3",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "^25.1.8",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "build": {
    "appId": "com.ebl.tablet-studio",
    "productName": "eBL Tablet Studio",
    "artifactName": "eBL_Tablet_Studio-${version}-${os}-${arch}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "ludovicus-hispanicus",
      "repo": "ebl-tablet-studio"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!weights/**",
          "!__pycache__/**",
          "!*.pyc"
        ]
      },
      {
        "from": "resources/stitcher",
        "to": "stitcher",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "eBL_Tablet_Studio-${version}-win-x64-setup.${ext}"
    },
    "portable": {
      "artifactName": "eBL_Tablet_Studio-${version}-win-x64-portable.${ext}"
    },
    "mac": {
      "icon": "assets/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "linux": {
      "icon": "assets/icons/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
